{
	"name": "fin-plan-shell",
	"version": "0.0.1",
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@vitest/browser-playwright": "^4.0.18",
		"jsdom": "^28.1.0",
		"playwright": "^1.58.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	},
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && biome check --write .",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"type": "module"
}
