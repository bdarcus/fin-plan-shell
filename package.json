{
	"name": "fin-plan-shell",
	"version": "0.0.1",
	"license": "MIT",
	"author": "Bruce D'Arcus",
	"private": false,
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.53.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/eslint__js": "^9.14.0",
		"@vitest/browser-playwright": "^4.1.0",
		"eslint": "^10.0.2",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"jsdom": "^28.1.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.53.0",
		"svelte-check": "^4.4.2",
		"svelte-eslint-parser": "^1.5.1",
		"tailwindcss": "^4.1.18",
		"typedoc": "^0.28.17",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^8.0.0",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && prettier --check . && eslint . && bun run docs:audit",
		"ci:verify": "bun run check && bun run test && bun run test:site",
		"docs:api": "typedoc",
		"docs:audit": "bun run ./scripts/docs-audit.ts",
		"format": "prettier --write .",
		"lint": "eslint .",
		"test:unit": "vitest",
		"test:site": "BASE_PATH=/fin-plan-shell bun run build && BASE_PATH=/fin-plan-shell bun test ./tests/static-site.smoke.test.ts",
		"test": "bun test packages ./tests/base-path-resolver.test.ts ./tests/planning-store.persistence.test.ts"
	},
	"type": "module"
}
